{
  "$defs": {
    "FinancialStatement": {
      "description": "A financial statement composed of ordered line items.",
      "properties": {
        "lines": {
          "items": {
            "$ref": "#/$defs/StatementLine"
          },
          "title": "Lines",
          "type": "array"
        },
        "name": {
          "enum": [
            "Income Statement",
            "Balance Sheet",
            "Cash Flow Statement"
          ],
          "title": "Name",
          "type": "string"
        },
        "periods": {
          "items": {
            "$ref": "#/$defs/ReportingPeriod"
