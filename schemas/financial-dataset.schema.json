          "type": "string"
        }
      },
      "required": [
        "entity_name",
        "periods",
        "records"
      ],
      "title": "NormalizedFinancialDataset",
      "type": "object"
    },
    "PeriodType": {
      "description": "Supported reporting period granularities.",
      "enum": [
        "month",
        "quarter",
        "year"
      ],
      "title": "PeriodType",
      "type": "string"
    },
    "ReportingPeriod": {
      "description": "A reporting period used as a model column.",
      "properties": {
        "end_date": {
          "format": "date",
          "title": "End Date",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
